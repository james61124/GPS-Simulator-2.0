# Copy to .env at repo root. Used by docker compose (env_file) and loaded by Django (see settings.py).

# --- MariaDB ---
MARIADB_HOSTNAME=mariadb
MARIADB_DATABASE=gpsdb
MARIADB_USER=gpsuser
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-me-root
MARIADB_PORT=3307

# --- Django (containers: set via compose; local: optional) ---
DJANGO_HOSTNAME=django
DJANGO_PORT=8000
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
# Comma-separated; include service name when using Docker network
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,django

# DB_* reserved for future MySQL settings (Django currently uses sqlite in repo default)

# --- Device service (FastAPI on the host machine) ---
# Django proxies to this URL. Must match nginx `location /device-api/` upstream if you use nginx.
DEVICE_SERVICE_URL=http://host.docker.internal:9100
# Legacy alias still read by Django if DEVICE_SERVICE_URL is unset:
# DEVICE_SERVICE_BASE_URL=http://host.docker.internal:9100

# --- Google Sign-In ---
# Browser (Next) needs NEXT_PUBLIC_*; Django verifies tokens with GOOGLE_CLIENT_ID.
# Use the same client ID string for both, or set only NEXT_PUBLIC_* and Django will fall back.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# --- Next.js (server-side only: rewrites + API routes) ---
# In Docker: Django service name. Local dev: http://127.0.0.1:8000
INTERNAL_DJANGO_URL=http://django:8000

# Browser-visible API base (optional; use if the client ever needs absolute URLs)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_DEVICE_API_BASE_URL=http://localhost:8080/device-api

# Comma-separated origins for Django CORS + CSRF (browser + nginx entrypoints)
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# --- Compose service names / ports ---
NEXT_HOSTNAME=frontend
NEXT_PORT=3000
NGINX_HOSTNAME=nginx
NGINX_PORT=8080
